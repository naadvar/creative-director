# Copy this file to .env and fill in your values.

# YouTube Data API v3 key (required). See README for setup.
YOUTUBE_API_KEY=

# Database. SQLite for MVP; swap to postgresql://... when you outgrow it.
DATABASE_URL=sqlite:///./data/creative_director.db

# Storage paths
THUMBNAIL_DIR=./data/thumbnails
TEMP_VIDEO_DIR=./data/tmp

# Feature flags (turn off heavy extractors if you're iterating fast)
ENABLE_VIDEO_DOWNLOAD=true
ENABLE_AUDIO_TRANSCRIPT=true
ENABLE_CLIP_EMBEDDINGS=true
ENABLE_FACE_DETECTION=true
ENABLE_OCR=true

# Whisper model: tiny, base, small, medium, large-v3
WHISPER_MODEL=base

# CLIP model
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k

# Optional: explicit path to tesseract.exe on Windows if not on PATH
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Max video resolution to download (lower = faster, less bandwidth)
MAX_VIDEO_HEIGHT=720

# Optional residential proxy for yt-dlp. Required when running from Colab/datacenter IPs
# at any meaningful volume. Decodo format:
# YTDLP_PROXY=http://USER:PASS@gate.decodo.com:7000

LOG_LEVEL=INFO
