{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://grow-brands-barely-dame.trycloudflare.com/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
